{
  "dashboard": {
    "title": "Application Monitoring",
    "tags": ["nestjs", "monitoring", "logs"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "🔴 Errors in Last Hour",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"nestjs\"} |= \"error\" [1h]))",
            "refId": "A",
            "datasource": "Loki"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "📊 Total Requests Today",
        "type": "stat",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"nestjs\"} [24h]))",
            "refId": "A",
            "datasource": "Loki"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 3,
        "title": "👤 Active Users (Audit)",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "count(count by (userId) (count_over_time({job=\"audit\"} [1h])))",
            "refId": "A",
            "datasource": "Loki"
          }
        ]
      },
      {
        "id": 4,
        "title": "⚠️ Failed Logins",
        "type": "stat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(count_over_time({job=\"audit\", action=\"login_failed\"} [1h]))",
            "refId": "A",
            "datasource": "Loki"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "📈 Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate({job=\"nestjs\"} [5m]))",
            "refId": "A",
            "legendFormat": "Requests/sec",
            "datasource": "Loki"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "🔴 Error Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate({job=\"nestjs\", level=\"error\"} [5m]))",
            "refId": "A",
            "legendFormat": "Errors/sec",
            "datasource": "Loki"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "errors/sec"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [5], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "High Error Rate",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 7,
        "title": "🔍 Recent Errors",
        "type": "logs",
        "gridPos": {"x": 0, "y": 12, "w": 24, "h": 10},
        "targets": [
          {
            "expr": "{job=\"nestjs-errors\"} |= \"error\"",
            "refId": "A",
            "datasource": "Loki"
          }
        ],
        "options": {
          "showLabels": true,
          "showTime": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 8,
        "title": "👥 Top Users by Activity",
        "type": "table",
        "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "topk(10, sum by (userId) (count_over_time({job=\"audit\"} [24h])))",
            "refId": "A",
            "datasource": "Loki",
            "format": "table"
          }
        ]
      },
      {
        "id": 9,
        "title": "🎯 Top Actions",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (action) (count_over_time({job=\"audit\"} [24h]))",
            "refId": "A",
            "datasource": "Loki"
          }
        ]
      },
      {
        "id": 10,
        "title": "🌍 Requests by IP",
        "type": "table",
        "gridPos": {"x": 0, "y": 30, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "topk(20, sum by (ipAddress) (count_over_time({job=\"audit\"} [24h])))",
            "refId": "A",
            "datasource": "Loki",
            "format": "table"
          }
        ]
      },
      {
        "id": 11,
        "title": "⏱️ Response Time (if available)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 30, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "refId": "A",
            "legendFormat": "p95",
            "datasource": "Prometheus"
          }
        ]
      },
      {
        "id": 12,
        "title": "🔎 All Application Logs",
        "type": "logs",
        "gridPos": {"x": 0, "y": 38, "w": 24, "h": 12},
        "targets": [
          {
            "expr": "{job=\"nestjs\"}",
            "refId": "A",
            "datasource": "Loki"
          }
        ],
        "options": {
          "showLabels": true,
          "showTime": true,
          "wrapLogMessage": true,
          "sortOrder": "Descending",
          "enableLogDetails": true
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  }
}
